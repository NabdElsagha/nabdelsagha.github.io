<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>أسعار الذهب والعملات في مصر</title>
    <style>
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background-color: #f4f4f9; text-align: center; padding: 20px; }
        .container { max-width: 600px; margin: auto; background: white; padding: 20px; border-radius: 15px; box-shadow: 0 4px 15px rgba(0,0,0,0.1); }
        h1 { color: #d4af37; border-bottom: 2px solid #d4af37; padding-bottom: 10px; }
        .price-card { display: flex; justify-content: space-between; padding: 15px; border-bottom: 1px solid #eee; font-size: 1.2rem; }
        .price-card:last-child { border-bottom: none; }
        .label { font-weight: bold; color: #333; }
        .price { color: #27ae60; font-weight: bold; }
        .update-time { font-size: 0.8rem; color: #888; margin-top: 20px; }
        .btn-refresh { margin-top: 20px; padding: 10px 20px; background: #d4af37; color: white; border: none; border-radius: 5px; cursor: pointer; }
    </style>
</head>
<body>

<div class="container">
    <h1>أسعار الذهب والعملات بمصر</h1>
    
    <div id="gold-prices">
        <div class="price-card"><span class="label">عيار 24:</span> <span class="price" id="g24">جاري التحميل...</span></div>
        <div class="price-card"><span class="label">عيار 21:</span> <span class="price" id="g21">جاري التحميل...</span></div>
        <div class="price-card"><span class="label">عيار 18:</span> <span class="price" id="g18">جاري التحميل...</span></div>
    </div>

    <hr>

    <div id="currency-prices">
        <div class="price-card"><span class="label">الدولار (بنك):</span> <span class="price" id="usd">جاري التحميل...</span></div>
        <div class="price-card"><span class="label">اليورو:</span> <span class="price" id="eur">جاري التحميل...</span></div>
    </div>

    <button class="btn-refresh" onclick="fetchPrices()">تحديث الآن</button>
    <p class="update-time">يتم التحديث تلقائياً كل دقيقة</p>
</div>

<script>
    async function fetchPrices() {
        try {
            // ملاحظة: ستحتاج لاستخدام API Key من موقع مثل goldapi.io أو metalpriceapi
            // هذا مثال توضيحي لكيفية الربط
            const response = await fetch('https://api.exchangerate-api.com/v4/latest/USD');
            const data = await response.json();
            const egpRate = data.rates.EGP;

            // تحديث العملات
            document.getElementById('usd').innerText = egpRate.toFixed(2) + " ج.م";
            document.getElementById('eur').innerText = (egpRate * 1.08).toFixed(2) + " ج.م"; // تقريبي

            // معادلة حساب الذهب (السعر العالمي / 31.1 * سعر الدولار * العيار)
            const goldOunceUSD = 2100; // مثال للسعر العالمي
            const price24 = (goldOunceUSD / 31.1) * egpRate;
            
            document.getElementById('g24').innerText = Math.round(price24) + " ج.م";
            document.getElementById('g21').innerText = Math.round(price24 * 0.875) + " ج.م";
            document.getElementById('g18').innerText = Math.round(price24 * 0.75) + " ج.m";

        } catch (error) {
            console.error("خطأ في جلب البيانات");
        }
    }

    fetchPrices();
    setInterval(fetchPrices, 60000); // تحديث كل دقيقة
</script>

</body>
</html>
